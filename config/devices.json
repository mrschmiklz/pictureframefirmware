{
  "profiles": [
    {
      "id": "pf109_aimor",
      "name": "AEEZO / YHK PF109 (Aimor)",
      "tested": true,
      "match": {
        "any_of": [
          { "ro.es_frame.product": "PF109" },
          { "ro.product.brand": "AEEZO", "ro.product.manufacturer": "YHK" }
        ],
        "packages": ["com.efercro.os.aimor"],
        "usb_vid_pid": ["1F3A:1007"]
      },
      "device": {
        "aimor_package": "com.efercro.os.aimor",
        "image_dir": "/sdcard/aimor/image",
        "aimor_db": "/data/data/com.efercro.os.aimor/databases/db_aimor.db",
        "launcher_apk": "/system/priv-app/launcher_aimor/launcher_aimor.apk",
        "photo_width": 1280,
        "photo_height": 800,
        "boot_hook": "setmacaddr",
        "splash_patch": true,
        "rclone_arch": "linux-arm"
      },
      "notes": "Allwinner A33, Android 6.0.1 eng build. Primary development target."
    },
    {
      "id": "aimor_white_label",
      "name": "White-label Aimor digital frame",
      "tested": false,
